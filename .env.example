# Copia este archivo como .env.local y rellena los valores de tu proyecto de Supabase.
# Estas dos claves son públicas por diseño (se exponen al navegador).
# NUNCA pongas aquí la service_role key.
#
# Sin estas variables la app funciona completa en modo invitado: solo quedan
# deshabilitados el historial de cuenta y el panel de administración.

NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key

# El acceso a /admin NO se configura aquí. Una variable NEXT_PUBLIC_ viaja al
# navegador, así que nunca sería una barrera real: el administrador se registra
# en la base de datos y la validación ocurre en el servidor.
#   insert into public.admins (email) values ('tucorreo@ejemplo.com');
